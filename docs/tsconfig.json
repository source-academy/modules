{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "./.vitepress/**/*.ts",
    "./src/**/*.md",
    "./src/**/*.ts",
    "./src/**/*.vue",
  ],
  "vueCompilerOptions": {
    "vitePressExtensions": [".md"]
  }
}
