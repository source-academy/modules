{
  "wcompile": {
    "kind": "function",
    "name": "wcompile",
    "description": "<p>Compile a (hopefully valid) WebAssembly Text module to binary.</p>",
    "params": [
      {
        "paramType": "regular",
        "type": "string",
        "name": "program"
      }
    ],
    "retType": "number[]"
  },
  "wrun": {
    "kind": "function",
    "name": "wrun",
    "description": "<p>Run a compiled WebAssembly Binary Buffer.</p>",
    "params": [
      {
        "paramType": "regular",
        "type": "Uint8Array<ArrayBufferLike> | number[]",
        "name": "buffer"
      }
    ],
    "retType": "AlternatingLinkedList<string, ExportValue>"
  }
}