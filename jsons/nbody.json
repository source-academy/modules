{
  "createCelestialBody": {
    "kind": "function",
    "name": "createCelestialBody",
    "description": "<p>Create a new celestial body.</p>",
    "params": [
      {
        "paramType": "regular",
        "type": "string",
        "name": "label"
      },
      {
        "paramType": "regular",
        "type": "number",
        "name": "mass"
      },
      {
        "paramType": "optional",
        "type": "number",
        "name": "radius"
      },
      {
        "paramType": "optional",
        "type": "Vector3",
        "name": "position"
      },
      {
        "paramType": "optional",
        "type": "Vector3",
        "name": "velocity"
      },
      {
        "paramType": "optional",
        "type": "Vector3",
        "name": "acceleration"
      }
    ],
    "retType": "CelestialBody"
  },
  "createCentripetalForce": {
